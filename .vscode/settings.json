{
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
    "python.terminal.activateEnvironment": true,
    "python.terminal.activateEnvInCurrentTerminal": true,
    "explorer.excludeGitIgnore": false,
    "search.useIgnoreFiles": false,
    "jupyter.interactiveWindow.textEditor.executeSelection": true, // run selected lines without needing a full cell
    "jupyter.askForKernelRestart": false // skip confirmation dialog on restart (faster recovery from hangs)
}
